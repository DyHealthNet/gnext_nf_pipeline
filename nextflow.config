nextflow.enable.dsl = 2

// ------------------------------------------------------
// Manifest
// ------------------------------------------------------
manifest {
    name        = 'GNExT Nextflow Pipeline'
    author      = 'Lis Arend'
    description = 'Pipeline for generating data for the GNExT platform'
    version     = '0.1.0'
}

// ------------------------------------------------------
// Global defaults
// ------------------------------------------------------
conda {
    enabled = true
    createTimeout = '1h'
}

includeConfig 'configs/base.config'

// Include shared compute profiles
includeConfig 'configs/compute.config'

// ------------------------------------------------------
// Study-specific config
// ------------------------------------------------------
includeConfig 'configs/study_specific.config'

// ------------------------------------------------------
// Process-specific overrides
// ------------------------------------------------------

process {
    withName: ENSEMBLVEP_VEP {
        ext.args = "--everything --offline --format vcf --distance ${params.ensemblvep_distance_up},${params.ensemblvep_distance_down} --vcf --af --af_gnomade --af_gnomadg"
        ext.prefix = "annotated_full_variants"
        cpus = params.vcf_cpus ?: 16
        memory = params.vcf_memory ?: '64 GB'
    }

    withName: ENSEMBLVEP_DOWNLOAD {
        ext.args = "--AUTO c --NO_UPDATE"
        cpus = params.vcf_cpus ?: 16
        memory = params.vcf_memory ?: '64 GB'
    }
}

profiles {

    conda {
        conda.enabled = true
        docker.enabled = false        
        singularity.enabled = false   
        process.conda = "envs/gnext_nf_pipeline.yml"
        
        // Override for VEP processes to use conda
        process {
            withName: ENSEMBLVEP_VEP {
                conda = "envs/vep_${params.ensemblvep_cache_version}.yml"
                ext.args = "--everything --offline --format vcf --distance ${params.ensemblvep_distance_up},${params.ensemblvep_distance_down} --vcf --af --af_gnomade --af_gnomadg"
                ext.prefix = "annotated_full_variants"
                cpus = params.vcf_cpus ?: 16
                memory = params.vcf_memory ?: '64 GB'
            }
            withName: ENSEMBLVEP_DOWNLOAD {
                conda = "envs/vep_${params.ensemblvep_cache_version}.yml"
                ext.args = "--AUTO c --NO_UPDATE"
                cpus = params.vcf_cpus ?: 16
                memory = params.vcf_memory ?: '64 GB'
            }
        }
    }

    // SLURM profile
    slurm {
        process.executor = "slurm"
        process.queue = params.slurm_queue
        process.maxForks = params.global_maxForks ?: 8
    }

    // Docker profile
    docker {
        docker.enabled = true
        conda.enabled = false
        docker.runOptions = "-u \$(id -u):\$(id -g) -v ${params.base_dir}:${params.base_dir}"
        process.container = "ghcr.io/dyhealthnet/gnext_nf_pipeline_dependencies:main"
        
        // VEP-specific containers
        process {
            withName: ENSEMBLVEP_VEP {
                container = "ensemblorg/ensembl-vep:release_${params.ensemblvep_cache_version}.0"
                ext.args = "--everything --offline --format vcf --distance ${params.ensemblvep_distance_up},${params.ensemblvep_distance_down} --vcf --af --af_gnomade --af_gnomadg"
                ext.prefix = "annotated_full_variants"
                cpus = params.vcf_cpus ?: 16
                memory = params.vcf_memory ?: '64 GB'
            }
            withName: ENSEMBLVEP_DOWNLOAD {
                container = "ensemblorg/ensembl-vep:release_${params.ensemblvep_cache_version}.0"
                ext.args = "--AUTO c --NO_UPDATE"
                cpus = params.vcf_cpus ?: 16
                memory = params.vcf_memory ?: '64 GB'
            }
        }
    }

    // Singularity profile
    singularity {
        singularity.enabled = true  // ← Move it here
        singularity.autoMounts = true
        singularity.runOptions = "-B ${params.base_dir}:${params.base_dir} -B ${projectDir}/.singularity_cache:/opt/conda/share/.assets"
        
        conda.enabled = false
        process.container = "ghcr.io/dyhealthnet/gnext_nf_pipeline_dependencies:main"
        
        // VEP-specific containers
        process {
            withName: ENSEMBLVEP_VEP {
                container = "ensemblorg/ensembl-vep:release_${params.ensemblvep_cache_version}.0"
                ext.args = "--everything --offline --format vcf --distance ${params.ensemblvep_distance_up},${params.ensemblvep_distance_down} --vcf --af --af_gnomade --af_gnomadg"
                ext.prefix = "annotated_full_variants"
                cpus = params.vcf_cpus ?: 16
                memory = params.vcf_memory ?: '64 GB'
            }
            withName: ENSEMBLVEP_DOWNLOAD {
                container = "ensemblorg/ensembl-vep:release_${params.ensemblvep_cache_version}.0"
                ext.args = "--AUTO c --NO_UPDATE"
                cpus = params.vcf_cpus ?: 16
                memory = params.vcf_memory ?: '64 GB'
            }
        }
    }
}